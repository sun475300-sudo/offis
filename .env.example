# Offis - Environment Variables
# Copy this file to .env and fill in your API keys

# ─── LLM API ────────────────────────────────────────────────────────────────
# Anthropic Claude (recommended)
# Get key: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=

# OpenAI GPT-4 (alternative)
# Get key: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# Minimax (Korean LLM alternative)
# Get key: https://api.minimax.chat/
VITE_MINIMAX_API_KEY=

# ─── GitHub API ──────────────────────────────────────────────────────────────
# Personal Access Token for reading PRs and diffs
# Get token: https://github.com/settings/tokens (scope: repo, read:user)
VITE_GITHUB_TOKEN=

# Default repository to analyze (used in /review command)
VITE_GITHUB_OWNER=sun475300-sudo
VITE_GITHUB_REPO=offis
